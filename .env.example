# Postgres (Neon, Supabase, local docker — anything speaking pg)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evergreen?schema=public"

# NextAuth v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Transactional email (Resend). Needed for password reset + email verification.
# Domain evergreen.app must be verified in your Resend account.
RESEND_API_KEY=""
EMAIL_FROM="Evergreen Studio <studio@evergreen.app>"

# LLM
ANTHROPIC_API_KEY=""

# M7+: Ayrshare (unified publishing API). Not needed until the publish milestone.
AYRSHARE_API_KEY=""
